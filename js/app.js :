let geminiApiKey = '';
let currentLanguage = 'en';

/**
 * Build the effective system prompt, appending language instruction if needed.
 */
const getSystemPrompt = () => {
  let prompt = SYSTEM_PROMPT;
  if (currentLanguage && currentLanguage !== 'en') {
    prompt += `\n\nIMPORTANT: The user has selected "${currentLanguage}" as their preferred language. Respond in that language unless the user writes in a different language.`;
  }
  return prompt;
};

/**
 * Validate an API key has a plausible format (non-empty, starts with "AI").
 * Gemini keys typically start with "AIza".
 */
const isValidApiKey = (key) => typeof key === 'string' && key.trim().length >= 10;

/**
 * Load the saved API key from localStorage and update the UI accordingly.
 */
const loadApiKey = () => {
  const saved = localStorage.getItem(CONFIG.localStorageKeys.apiKey);
  if (saved && isValidApiKey(saved)) {
    geminiApiKey = saved;
    showChatInterface();
  } else {
    showApiKeyPanel();
  }
};

/**
 * Save the API key entered by the user.
 */
const saveApiKey = () => {
  const key = DOM.apiKeyInput?.value?.trim();
  if (!key) {
    showToast('Please enter an API key.', 'warning');
    return;
  }
  if (!isValidApiKey(key)) {
    showToast('API key appears invalid. Please check and try again.', 'error');
    return;
  }
  geminiApiKey = key;
  localStorage.setItem(CONFIG.localStorageKeys.apiKey, key);
  showToast('API key saved successfully!', 'success');
  showChatInterface();
};

const showChatInterface = () => {
  if (DOM.apiKeyPanel) DOM.apiKeyPanel.style.display = 'none';
  if (DOM.chatContainer) DOM.chatContainer.style.display = '';
};

const showApiKeyPanel = () => {
  if (DOM.apiKeyPanel) DOM.apiKeyPanel.style.display = '';
  if (DOM.chatContainer) DOM.chatContainer.style.display = 'none';
};

/**
 * Send a prompt to the Gemini API and return the text response.
 * @param {string} prompt  User message or constructed prompt
 * @param {string} [systemOverride]  Optional system prompt override
 * @returns {Promise<string>}
 */
const callGemini = async (prompt, systemOverride) => {
  if (!geminiApiKey) {
    throw new Error('Gemini API key not configured.');
  }

  const url = `${CONFIG.geminiEndpoint}?key=${geminiApiKey}`;

  const body = {
    contents: [{ parts: [{ text: prompt }] }],
    systemInstruction: { parts: [{ text: systemOverride || getSystemPrompt() }] },
    generationConfig: {
      temperature: CONFIG.defaultTemperature,
      maxOutputTokens: CONFIG.maxOutputTokens,
    },
  };

  const response = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });

  if (!response.ok) {
    const err = await response.json().catch(() => ({}));
    const msg = err?.error?.message || `HTTP ${response.status}`;
    throw new Error(msg);
  }

  const data = await response.json();
  const text =
    data?.candidates?.[0]?.content?.parts?.[0]?.text || 'No response received.';
  return text;
};

