/**
 * Append a message bubble to the chat window.
 * @param {string} text
 * @param {'user'|'ai'} sender
 */
const appendMessage = (text, sender = 'ai') => {
  const container = DOM.chatMessages;
  if (!container) return;

  const msg = document.createElement('div');
  msg.className = `message message-${sender}`;

  const content = document.createElement('div');
  content.className = 'message-content';

  const msgText = document.createElement('div');
  msgText.className = 'message-text';
  msgText.innerHTML = sender === 'ai' ? parseMarkdown(text) : escapeHtml(text);

  const time = document.createElement('span');
  time.className = 'message-time';
  time.textContent = formatTime(new Date());

  content.appendChild(msgText);
  content.appendChild(time);
  msg.appendChild(content);
  container.appendChild(msg);

  scrollChatToBottom();
};

/**
 * Escape HTML for user-submitted text.
 */
const escapeHtml = (text) =>
  text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');

/**
 * Show the typing indicator in the chat.
 * @returns {HTMLElement} The indicator element (for later removal).
 */
const showTypingIndicator = () => {
  const container = DOM.chatMessages;
  if (!container) return null;

  const indicator = document.createElement('div');
  indicator.className = 'message message-ai typing-indicator';
  indicator.id = 'typing-indicator';
  indicator.innerHTML = `
    <div class="message-content">
      <div class="message-text">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </div>
    </div>`;
  container.appendChild(indicator);
  scrollChatToBottom();
  return indicator;
};

const removeTypingIndicator = () => {
  const el = document.getElementById('typing-indicator');
  if (el) el.remove();
};

const scrollChatToBottom = () => {
  const container = DOM.chatMessages;
  if (container) {
    requestAnimationFrame(() => {
      container.scrollTop = container.scrollHeight;
    });
  }
};

/**
 * Handle sending a chat message.
 */
const sendChatMessage = async () => {
  const input = DOM.chatInput;
  if (!input) return;

  const text = input.value.trim();
  if (!text) return;

  // Clear input
  input.value = '';
  input.style.height = 'auto';

  // Add user message
  appendMessage(text, 'user');

  // Show typing
  showTypingIndicator();

  try {
    const reply = await callGemini(text);
    removeTypingIndicator();
    appendMessage(reply, 'ai');
  } catch (err) {
    removeTypingIndicator();
    appendMessage('Sorry, I encountered an error. Please try again.', 'ai');
    showToast(`AI Error: ${err.message}`, 'error');
    console.error('[Gemini]', err);
  }
};

const initChat = () => {
  // Send button
  DOM.sendBtn?.addEventListener('click', sendChatMessage);

  // Enter to send, Shift+Enter for newline
  DOM.chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendChatMessage();
    }
  });

  // Auto-resize textarea
  DOM.chatInput?.addEventListener('input', () => {
    const el = DOM.chatInput;
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 150) + 'px';
  });

  // Save API key button
  DOM.saveApiKey?.addEventListener('click', saveApiKey);

  // Also save on Enter in API key input
  DOM.apiKeyInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      saveApiKey();
    }
  });

  // Suggested prompts (event delegation)
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.suggested-prompt, [data-prompt]');
    if (!btn) return;
    const prompt = btn.dataset.prompt || btn.textContent.trim();
    if (prompt && DOM.chatInput) {
      DOM.chatInput.value = prompt;
      // Switch to assistant tab if not already there
      switchTab('assistant');
      sendChatMessage();
    }
  });

  loadApiKey();
};

