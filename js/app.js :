let mapZoom = 1;
const MAP_ZOOM_STEP = 0.2;
const MAP_ZOOM_MIN = 0.5;
const MAP_ZOOM_MAX = 3;

const initStadiumNavigator = () => {
  const map = DOM.stadiumMap;
  if (!map) return;

  // Hover & click on SVG sections
  map.addEventListener('mouseover', (e) => {
    const section = e.target.closest('.map-section');
    if (section) section.classList.add('hovered');
  });

  map.addEventListener('mouseout', (e) => {
    const section = e.target.closest('.map-section');
    if (section) section.classList.remove('hovered');
  });

  map.addEventListener('click', (e) => {
    const section = e.target.closest('.map-section');
    if (!section) return;

    // Remove previous selection
    map.querySelectorAll('.map-section.selected').forEach((s) =>
      s.classList.remove('selected')
    );
    section.classList.add('selected');

    const sectionName = section.dataset.name || section.id || 'Section';
    showToast(`Selected: ${sectionName}`, 'info', 2000);
  });

  // Zoom controls
  document.getElementById('zoom-in')?.addEventListener('click', () => {
    mapZoom = Math.min(mapZoom + MAP_ZOOM_STEP, MAP_ZOOM_MAX);
    applyMapZoom();
  });

  document.getElementById('zoom-out')?.addEventListener('click', () => {
    mapZoom = Math.max(mapZoom - MAP_ZOOM_STEP, MAP_ZOOM_MIN);
    applyMapZoom();
  });

  document.getElementById('zoom-reset')?.addEventListener('click', () => {
    mapZoom = 1;
    applyMapZoom();
  });

  // Toggle labels
  document.getElementById('toggle-labels')?.addEventListener('click', () => {
    map.classList.toggle('hide-labels');
  });

  // AI Directions
  document.getElementById('get-directions')?.addEventListener('click', getAIDirections);

  // Search
  const navSearch = document.getElementById('nav-search');
  if (navSearch) {
    navSearch.addEventListener(
      'input',
      debounce((e) => {
        const query = e.target.value.toLowerCase();
        map.querySelectorAll('.map-section').forEach((section) => {
          const name = (section.dataset.name || section.id || '').toLowerCase();
          section.classList.toggle('highlight', name.includes(query) && query.length > 0);
        });
      }, 250)
    );
  }
};

const applyMapZoom = () => {
  const map = DOM.stadiumMap;
  if (!map) return;
  map.style.transform = `scale(${mapZoom})`;
  map.style.transformOrigin = 'center center';
};

/**
 * Get AI-powered walking directions inside the stadium.
 */
const getAIDirections = async () => {
  const fromEl = document.getElementById('direction-from');
  const toEl = document.getElementById('direction-to');
  const resultEl = document.getElementById('directions-result');
  const accessibleCheck = document.getElementById('accessible-route');

  const from = fromEl?.value?.trim();
  const to = toEl?.value?.trim();

  if (!from || !to) {
    showToast('Please enter both starting and destination locations.', 'warning');
    return;
  }

  if (resultEl) resultEl.innerHTML = '<p class="loading-text">⏳ Generating directions…</p>';

  const accessibilityNote = accessibleCheck?.checked
    ? ' Include detailed accessibility notes and wheelchair-accessible paths.'
    : '';

  const prompt = `Give step-by-step walking directions inside a stadium from ${from} to ${to}. Include estimated walking time.${accessibilityNote}`;

  try {
    const reply = await callGemini(prompt);
    if (resultEl) resultEl.innerHTML = parseMarkdown(reply);
  } catch (err) {
    if (resultEl) resultEl.innerHTML = '<p class="error-text">Failed to get directions. Please try again.</p>';
    showToast(`Directions error: ${err.message}`, 'error');
  }
};

