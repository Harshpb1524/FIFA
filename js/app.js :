const CROWD_ZONES = [
  'North Stand', 'South Stand', 'East Stand', 'West Stand',
  'VIP Lounge', 'Concourse A', 'Concourse B', 'Gate 1',
  'Gate 2', 'Gate 3', 'Food Court', 'Fan Zone',
];

let crowdData = {};
let crowdInterval = null;

/**
 * Generate random crowd density data for each zone.
 */
const generateCrowdData = () => {
  const data = {};
  CROWD_ZONES.forEach((zone) => {
    data[zone] = {
      density: randInt(15, 98),
      trend: pickRandom(['rising', 'falling', 'stable']),
      count: randInt(200, 5000),
    };
  });
  return data;
};

/**
 * Initialise or reset the crowd heatmap grid.
 */
const initCrowdHeatmap = () => {
  const heatmap = DOM.crowdHeatmap;
  if (!heatmap || heatmap.children.length > 0) return; // already built

  // 8 columns × 6 rows = 48 cells
  for (let r = 0; r < 6; r++) {
    for (let c = 0; c < 8; c++) {
      const cell = document.createElement('div');
      cell.className = 'heatmap-cell';
      cell.dataset.row = r;
      cell.dataset.col = c;
      cell.dataset.level = '0';
      heatmap.appendChild(cell);
    }
  }
};

/**
 * Refresh crowd data, update heatmap colours, zone table, and KPIs.
 */
const refreshCrowdData = () => {
  crowdData = generateCrowdData();

  // Update heatmap cells
  const cells = DOM.crowdHeatmap?.querySelectorAll('.heatmap-cell');
  if (cells) {
    cells.forEach((cell) => {
      const level = randInt(0, 4); // 0=empty, 4=critical
      cell.dataset.level = level;
    });
  }

  // Update zone table
  const tbody = document.querySelector('#crowd-zone-table tbody, .zone-table tbody');
  if (tbody) {
    tbody.innerHTML = '';
    Object.entries(crowdData).forEach(([zone, info]) => {
      const row = document.createElement('tr');
      const trendIcon = info.trend === 'rising' ? '📈' : info.trend === 'falling' ? '📉' : '➡️';
      const levelClass =
        info.density > 85 ? 'critical' : info.density > 65 ? 'high' : info.density > 40 ? 'moderate' : 'low';
      row.innerHTML = `
        <td>${zone}</td>
        <td>${info.count.toLocaleString()}</td>
        <td><span class="density-badge ${levelClass}">${info.density}%</span></td>
        <td>${trendIcon} ${info.trend}</td>`;
      tbody.appendChild(row);
    });
  }

  // Occupancy ring
  const totalDensity = Math.round(
    Object.values(crowdData).reduce((sum, z) => sum + z.density, 0) / CROWD_ZONES.length
  );
  const occupancyEl = document.getElementById('occupancy-value');
  if (occupancyEl) animateNumber(occupancyEl, totalDensity, 1000);

  // Update progress ring if exists
  const ring = document.querySelector('.progress-ring-circle');
  if (ring) {
    const circumference = 2 * Math.PI * (ring.r?.baseVal?.value || 54);
    ring.style.strokeDasharray = circumference;
    ring.style.strokeDashoffset = circumference * (1 - totalDensity / 100);
  }

  // Entry rate
  const entryRateEl = document.getElementById('entry-rate');
  if (entryRateEl) animateNumber(entryRateEl, randInt(80, 350), 800);

  // AI crowd insights
  updateCrowdInsights();
};

/**
 * Generate AI-based crowd insights.
 */
const updateCrowdInsights = async () => {
  const insightsContainer = document.getElementById('crowd-insights');
  if (!insightsContainer) return;

  // Show quick local insights immediately (no API call needed)
  const highDensityZones = Object.entries(crowdData)
    .filter(([, z]) => z.density > 75)
    .map(([name]) => name);

  const insights = [
    `🔴 ${highDensityZones.length} zone(s) above 75% capacity: ${highDensityZones.join(', ') || 'None'}`,
    `📊 Average stadium occupancy: ${Math.round(Object.values(crowdData).reduce((s, z) => s + z.density, 0) / CROWD_ZONES.length)}%`,
    `🚶 Peak entry rate detected at Gate ${randInt(1, 3)} — consider opening auxiliary lanes`,
  ];

  insightsContainer.innerHTML = insights.map((i) => `<div class="insight-card">${i}</div>`).join('');
};

