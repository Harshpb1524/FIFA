/**
 * Switch to the specified tab.
 * @param {string} tabName  e.g. 'home', 'assistant'
 */
const switchTab = (tabName) => {
  // Deactivate all nav items and panels
  DOM.navItems.forEach((item) => item.classList.remove('active'));
  DOM.tabPanels.forEach((panel) => {
    panel.classList.remove('active');
    panel.style.display = 'none';
  });

  // Activate matching nav item
  const activeNav = document.querySelector(`.nav-item[data-tab="${tabName}"]`);
  if (activeNav) activeNav.classList.add('active');

  // Activate matching panel
  const activePanel = document.getElementById(`tab-${tabName}`);
  if (activePanel) {
    activePanel.classList.add('active');
    activePanel.style.display = '';
  }

  // Update page title
  if (DOM.pageTitle) {
    DOM.pageTitle.textContent = TAB_TITLES[tabName] || tabName;
  }

  // Update URL hash without scrolling
  history.replaceState(null, '', `#${tabName}`);

  // Close sidebar on mobile after navigation
  if (window.innerWidth <= 768 && DOM.sidebar) {
    DOM.sidebar.classList.remove('open');
  }

  // Fire tab-specific initialisation hooks
  onTabActivated(tabName);
};

/**
 * Read the current hash and switch to that tab (or default to 'home').
 */
const handleHashRoute = () => {
  const hash = window.location.hash.replace('#', '') || 'home';
  switchTab(hash);
};

/**
 * Hook called every time a tab becomes active. Use for lazy initialisation.
 * @param {string} tab
 */
const onTabActivated = (tab) => {
  switch (tab) {
    case 'crowd':
      initCrowdHeatmap();
      refreshCrowdData();
      break;
    case 'sustainability':
      animateSustainabilityCounters();
      break;
    case 'operations':
      refreshOperationsKPIs();
      break;
    default:
      break;
  }
};

const initNavigation = () => {
  // Click handlers on nav items (event delegation on sidebar)
  if (DOM.sidebar) {
    DOM.sidebar.addEventListener('click', (e) => {
      const navItem = e.target.closest('.nav-item');
      if (!navItem) return;
      const tab = navItem.dataset.tab;
      if (tab) switchTab(tab);
    });
  }

  // Mobile menu toggle
  if (DOM.menuToggle) {
    DOM.menuToggle.addEventListener('click', () => {
      DOM.sidebar?.classList.toggle('open');
    });
  }

  // Close sidebar when clicking outside on mobile
  document.addEventListener('click', (e) => {
    if (
      window.innerWidth <= 768 &&
      DOM.sidebar?.classList.contains('open') &&
      !DOM.sidebar.contains(e.target) &&
      e.target !== DOM.menuToggle
    ) {
      DOM.sidebar.classList.remove('open');
    }
  });

  // Hash routing
  window.addEventListener('hashchange', handleHashRoute);
  handleHashRoute();
};

