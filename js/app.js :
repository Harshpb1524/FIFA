/**
 * Generate a realistic match schedule around the current tournament window.
 */
const generateMatchSchedule = () => {
  const teams = [
    'Brazil', 'Argentina', 'France', 'Germany', 'Spain', 'England',
    'Portugal', 'Netherlands', 'Belgium', 'Italy', 'Uruguay', 'Mexico',
    'USA', 'Canada', 'Japan', 'South Korea', 'Australia', 'Saudi Arabia',
    'Morocco', 'Senegal', 'Nigeria', 'Ghana', 'Ecuador', 'Colombia',
    'Croatia', 'Denmark', 'Switzerland', 'Poland', 'Serbia', 'Cameroon',
    'Tunisia', 'Costa Rica',
  ];

  const matches = [];
  for (let i = 0; i < 8; i++) {
    const homeIdx = randInt(0, teams.length - 1);
    let awayIdx = randInt(0, teams.length - 1);
    while (awayIdx === homeIdx) awayIdx = randInt(0, teams.length - 1);

    const venue = pickRandom(VENUES);
    const hour = randInt(13, 21);
    const day = randInt(11, 18);

    matches.push({
      id: generateId(),
      home: teams[homeIdx],
      away: teams[awayIdx],
      venue: venue.name,
      city: venue.city,
      date: `July ${day}, 2026`,
      time: `${hour}:00`,
      stage: pickRandom(['Group Stage', 'Round of 32', 'Round of 16', 'Quarter-Final']),
      score: day < 12 ? `${randInt(0, 4)} - ${randInt(0, 3)}` : null, // past matches have scores
    });
  }

  return matches;
};

